generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          String   @id @default(uuid())
  name        String
  birthDate   DateTime
  cpf         String   @unique
  phone       String
  email       String   @unique
  fullAddress String

  @@index([name])
}
